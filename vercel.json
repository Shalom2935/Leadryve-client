{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html",
      "has": [
        {
          "type": "host",
          "value": "app.leadryve.com"
        }
      ]
    },
    {
      "source": "/privacy-policy",
      "destination": "/index.html",
      "has": [
        {
          "type": "host",
          "value": "leadryve.com"
        }
      ]
    },
    {
      "source": "/terms-of-service",
      "destination": "/index.html",
      "has": [
        {
          "type": "host",
          "value": "leadryve.com"
        }
      ]
    },
    {
      "source": "/pricing",
      "destination": "/index.html",
      "has": [
        {
          "type": "host",
          "value": "leadryve.com"
        }
      ]
    },
    {
      "source": "/",
      "destination": "/index.html",
      "has": [
        {
          "type": "host",
          "value": "leadryve.com"
        }
      ]
    },
    {
      "source": "/(.*)",
      "destination": "/index.html",
      "has": [
        {
          "type": "host",
          "value": "www.leadryve.com"
        }
      ]
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev"
}
